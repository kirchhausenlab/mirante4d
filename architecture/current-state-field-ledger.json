      "source_struct": "AppState",
      "fields": ["startup_diagnostics"],
      "action": "move",
      "target_owner": "mirante4d-app",
      "state_class": "diagnostic",
      "finalization_gate": "WP-07B",
      "reason": "Process and capability diagnostics are composition facts, never project state."
    },
    {
      "id": "appstate-delete-capability-mirror",
      "source_struct": "AppState",
      "fields": ["adapter_summary"],
      "action": "delete",
      "target_owner": "mirante4d-app",
      "state_class": "diagnostic",
      "finalization_gate": "WP-07B",
      "reason": "Derive the user-facing adapter summary from the composition-owned capability snapshot."
    },
    {
      "id": "appstate-delete-catalog-mirrors",
      "source_struct": "AppState",
      "fields": [
        "dataset_name",
        "layer_count",
        "active_layer_name",
