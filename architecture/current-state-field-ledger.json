  ],
  "invariants": {
    "every_source_field_exactly_once": true,
    "one_target_owner_or_deletion": true,
    "product_cutover_gate": "WP-07B",
    "no_live_target_model_in_wp07a": true,
    "appstate_predecessor_field_removal_gate": "WP-07B",
    "finalization_gate_meaning": "Latest gate for reaching the named final owner or deletion; the WP-07B entry must name a bounded temporary non-durable owner for every later-gated AppState fact."
  },
  "dispositions": [
    {
