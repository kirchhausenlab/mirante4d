      "finalization_gate": "WP-07B",
      "reason": "CameraView.projection is authoritative."
    },
    {
      "id": "appstate-split-layer-aggregate",
      "source_struct": "AppState",
      "fields": ["layers"],
      "action": "split",
      "target_owner": "mirante4d-dataset+mirante4d-project-model",
      "state_class": "immutable_and_durable",
      "finalization_gate": "WP-07B",
      "reason": "Catalog identity/name/shape/dtype move to dataset; display/render choices move to project-model. The aggregate is deleted."
