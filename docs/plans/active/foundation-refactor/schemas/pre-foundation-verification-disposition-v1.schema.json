{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mirante4d:foundation:pre-foundation-verification-disposition:v1",
  "title": "Sanitized pre-foundation verification disposition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema",
    "schema_version",
    "origin",
    "summary",
    "records",
    "post_wp02_new_record_ids"
  ],
  "properties": {
    "$schema": {
      "const": "../schemas/pre-foundation-verification-disposition-v1.schema.json"
    },
    "schema": {
      "const": "mirante4d-pre-foundation-verification-disposition"
    },
    "schema_version": {
      "const": 1
    },
    "origin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["public_epoch", "statement"],
      "properties": {
        "public_epoch": { "const": true },
        "statement": { "type": "string", "minLength": 1 }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_count",
        "deleted",
        "retained",
        "rewritten",
        "moved",
        "post_wp02_new_records"
      ],
      "properties": {
        "record_count": { "const": 1055 },
        "deleted": { "const": 62 },
        "retained": { "const": 990 },
        "rewritten": { "const": 2 },
        "moved": { "const": 1 },
        "post_wp02_new_records": { "const": 20 }
      }
    },
    "records": {
      "type": "array",
      "minItems": 1055,
      "maxItems": 1055,
      "items": { "$ref": "#/$defs/record" }
    },
    "post_wp02_new_record_ids": {
      "type": "array",
      "minItems": 20,
      "maxItems": 20,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "owner",
        "selector",
        "source_path",
        "ignored",
        "evidence_level",
        "related_case_ids",
        "selected_by",
        "classification",
        "disposition",
        "replacement_id",
        "disposition_reason"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1 },
        "selector": { "type": "string", "minLength": 1 },
        "source_path": { "type": "string", "minLength": 1 },
        "ignored": { "type": "boolean" },
        "evidence_level": { "type": "string", "minLength": 1 },
        "related_case_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "selected_by": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "classification": { "type": "string", "minLength": 1 },
        "disposition": {
          "enum": ["deleted", "retained", "rewritten", "moved"]
        },
        "replacement_id": {
          "type": ["string", "null"]
        },
        "disposition_reason": { "type": "string", "minLength": 1 }
      }
    }
  }
}
