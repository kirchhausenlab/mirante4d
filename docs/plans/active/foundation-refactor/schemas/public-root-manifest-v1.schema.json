{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mirante4d:foundation:public-root-manifest:v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema",
    "schema_version",
    "source_commit",
    "source_date_epoch",
    "git_object_format",
    "author_name",
    "author_email",
    "commit_message_utf8",
    "tree_oid",
    "commit_oid",
    "tag_name",
    "path_policy_sha256",
    "paths"
  ],
  "properties": {
    "$schema": { "const": "public-root-manifest-v1.schema.json" },
    "schema": { "const": "mirante4d-public-root-manifest" },
    "schema_version": { "const": 1 },
    "source_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "source_date_epoch": { "const": 1783729811 },
    "git_object_format": { "const": "sha1" },
    "author_name": { "const": "Mirante4D Contributors" },
    "author_email": { "const": "contributors@mirante4d.invalid" },
    "commit_message_utf8": { "const": "Initial public Mirante4D source snapshot\n" },
    "tree_oid": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "commit_oid": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "tag_name": { "const": "foundation-public-root-v1" },
    "path_policy_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "mode",
          "bytes",
          "sha256",
          "source_blob_oid",
          "public_blob_oid"
        ],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "mode": { "enum": ["100644", "100755"] },
          "bytes": { "type": "integer", "minimum": 1 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "source_blob_oid": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
          "public_blob_oid": { "type": "string", "pattern": "^[0-9a-f]{40}$" }
        }
      }
    }
  }
}
